FROM ghcr.io/cross-rs/armv7-unknown-linux-gnueabihf:main

# Install build tools, protoc, and x86_64 OpenSSL for HOST build scripts
ARG PROTOC_VERSION=25.1
RUN apt-get update && \
    apt-get install -y curl unzip pkg-config perl libssl-dev && \
    curl -LO "https://github.com/protocolbuffers/protobuf/releases/download/v${PROTOC_VERSION}/protoc-${PROTOC_VERSION}-linux-x86_64.zip" && \
    unzip "protoc-${PROTOC_VERSION}-linux-x86_64.zip" -d /usr/local && \
    rm "protoc-${PROTOC_VERSION}-linux-x86_64.zip" && \
    chmod +x /usr/local/bin/protoc && \
    rm -rf /var/lib/apt/lists/*

# ORT_USE_CUDA=0 prevents ONNX runtime from trying to use CUDA
ENV ORT_USE_CUDA=0

# Configure pkg-config for cross-compilation
ENV PKG_CONFIG_ALLOW_CROSS=1
