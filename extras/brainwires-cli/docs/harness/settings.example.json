{
  "permissions": {
    "allow": [
      "Read",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(cargo check*)",
      "Bash(cargo test*)"
    ],
    "deny": [
      "Bash(rm:*)",
      "Bash(sudo:*)",
      "Bash(mkfs:*)",
      "Bash(dd:*)",
      "Edit(/etc/**)",
      "Edit(/usr/**)"
    ],
    "ask": [
      "WebFetch",
      "Bash(git push*)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tee -a /tmp/bw-prompts.log >/dev/null",
            "timeout_ms": 200
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -c '{event, tool_name, cmd: .tool_args.command}' >> /tmp/bw-tools.log",
            "timeout_ms": 200
          }
        ]
      }
    ]
  },
  "env": {
    "RUST_LOG": "brainwires_cli=info"
  }
}
