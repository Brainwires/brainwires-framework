# Brainwires CLI Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The .env file is automatically loaded by tests and ignored by git.

# ============================================================================
# Test Configuration
# ============================================================================

# API key for running integration tests that require AI
#
# Production key (uses https://brainwires.studio):
# TEST_API_KEY=bw_your_test_key_here
#
# Development key (uses https://dev.brainwires.net):
# TEST_API_KEY=bw_dev_your_dev_key_here
#
# Keys starting with "bw_dev_" automatically use the dev server
TEST_API_KEY=bw_dev_...

# ============================================================================
# Optional: Runtime Configuration
# ============================================================================

# Default API key (can also be set via `brainwires auth login`)
# BRAINWIRES_API_KEY=bw_your_api_key_here

# Backend URL (defaults to production)
# BRAINWIRES_BACKEND_URL=https://api.brainwires.studio

# Default model to use
# BRAINWIRES_MODEL=claude-3-5-sonnet-20241022

# Enable debug logging
# RUST_LOG=debug

# ============================================================================
# Development Only
# ============================================================================

# Local backend for development
# BRAINWIRES_BACKEND_URL=http://localhost:3000

# Use local LanceDB instead of cloud
# BRAINWIRES_USE_LOCAL_DB=true
