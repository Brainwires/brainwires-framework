{
  "$schema": "https://brainwires.studio/schemas/cli-config.json",
  "version": "1.0",
  "description": "Default configuration - balanced settings for general use",

  "provider": {
    "default": "anthropic",
    "model": "claude-sonnet-4-20250514",
    "fallback_providers": ["openai", "ollama"]
  },

  "agent": {
    "max_iterations": 100,
    "enable_validation": true,
    "validation_config": {
      "checks": ["file_existence", "duplicates", "syntax"],
      "max_retries": 3
    },
    "mdap": {
      "enabled": false
    }
  },

  "tools": {
    "bash": {
      "timeout_seconds": 120,
      "allow_destructive": false
    },
    "file_operations": {
      "max_file_size_mb": 10,
      "backup_before_write": false
    },
    "web": {
      "timeout_seconds": 30,
      "user_agent": "brainwires-cli/0.6.0"
    }
  },

  "permissions": {
    "mode": "ask",
    "auto_approve": [
      "read_file",
      "list_directory",
      "query_codebase"
    ],
    "always_ask": [
      "bash",
      "write_file",
      "git_commit"
    ]
  },

  "storage": {
    "database_path": "~/.brainwires/data/lance.db",
    "memory_tiers": {
      "hot_max_messages": 100,
      "warm_max_age_hours": 24,
      "cold_compression": true
    },
    "embedding": {
      "model": "all-MiniLM-L6-v2",
      "cache_size": 1000
    }
  },

  "logging": {
    "level": "info",
    "file": "~/.brainwires/logs/cli.log",
    "rotation": {
      "max_size_mb": 10,
      "max_files": 5
    }
  },

  "ui": {
    "theme": "default",
    "show_token_count": true,
    "show_cost_estimate": true,
    "markdown_rendering": true
  }
}
