{
  "$schema": "https://brainwires.studio/schemas/cli-config.json",
  "version": "1.0",
  "description": "Cost-optimized configuration - minimize API usage while maintaining functionality",

  "provider": {
    "default": "anthropic",
    "model": "claude-3-5-haiku-20241022",
    "fallback_providers": ["ollama"],
    "prefer_local": true,
    "retry": {
      "max_attempts": 2,
      "backoff_multiplier": 1.5,
      "initial_delay_ms": 500
    }
  },

  "agent": {
    "max_iterations": 15,
    "enable_validation": true,
    "validation_config": {
      "checks": ["file_existence", "duplicates"],
      "max_retries": 2
    },
    "mdap": {
      "enabled": false
    },
    "early_stop": {
      "enabled": true,
      "confidence_threshold": 0.9
    }
  },

  "tools": {
    "bash": {
      "timeout_seconds": 60,
      "allow_destructive": false
    },
    "file_operations": {
      "max_file_size_mb": 5,
      "backup_before_write": false
    },
    "web": {
      "timeout_seconds": 15,
      "cache_responses": true,
      "cache_ttl_seconds": 300
    }
  },

  "permissions": {
    "mode": "auto",
    "auto_approve": [
      "read_file",
      "list_directory",
      "query_codebase",
      "write_file",
      "edit_file"
    ],
    "always_ask": [
      "bash",
      "delete_file",
      "git_push"
    ]
  },

  "storage": {
    "database_path": "~/.brainwires/data/lance.db",
    "memory_tiers": {
      "hot_max_messages": 50,
      "warm_max_age_hours": 12,
      "cold_compression": true
    },
    "embedding": {
      "model": "all-MiniLM-L6-v2",
      "cache_size": 500,
      "lazy_embed": true
    }
  },

  "context": {
    "max_tokens": 8000,
    "truncation_strategy": "smart",
    "include_system_prompt": true,
    "compress_history": true
  },

  "logging": {
    "level": "warn",
    "file": "~/.brainwires/logs/cli.log",
    "rotation": {
      "max_size_mb": 5,
      "max_files": 3
    }
  },

  "ui": {
    "theme": "minimal",
    "show_token_count": true,
    "show_cost_estimate": true,
    "markdown_rendering": false
  },

  "notes": [
    "This configuration minimizes API costs.",
    "Uses smaller/faster models (Haiku) by default.",
    "Prefers local Ollama when available.",
    "Lower iteration limits to prevent runaway costs.",
    "Auto-approves safe operations to reduce round-trips.",
    "MDAP disabled to avoid k× multiplier on API calls.",
    "Consider enabling MDAP only for truly complex tasks."
  ]
}
