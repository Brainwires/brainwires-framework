{
  "$schema": "https://brainwires.studio/schemas/cli-config.json",
  "version": "1.0",
  "description": "High-reliability configuration - maximum correctness for critical tasks",

  "provider": {
    "default": "anthropic",
    "model": "claude-sonnet-4-20250514",
    "fallback_providers": ["openai"],
    "retry": {
      "max_attempts": 5,
      "backoff_multiplier": 2.0,
      "initial_delay_ms": 1000
    }
  },

  "agent": {
    "max_iterations": 50,
    "enable_validation": true,
    "validation_config": {
      "checks": ["file_existence", "duplicates", "syntax", "build"],
      "max_retries": 5,
      "build_type": "auto"
    },
    "mdap": {
      "enabled": true,
      "preset": "high_reliability",
      "k": 5,
      "consensus_threshold": 0.8
    }
  },

  "tools": {
    "bash": {
      "timeout_seconds": 300,
      "allow_destructive": false,
      "sandbox_mode": true
    },
    "file_operations": {
      "max_file_size_mb": 5,
      "backup_before_write": true,
      "backup_dir": "~/.brainwires/backups"
    },
    "web": {
      "timeout_seconds": 60,
      "verify_ssl": true
    }
  },

  "permissions": {
    "mode": "ask",
    "auto_approve": [
      "read_file",
      "list_directory"
    ],
    "always_ask": [
      "bash",
      "write_file",
      "edit_file",
      "delete_file",
      "git_commit",
      "git_push"
    ]
  },

  "storage": {
    "database_path": "~/.brainwires/data/lance.db",
    "memory_tiers": {
      "hot_max_messages": 200,
      "warm_max_age_hours": 168,
      "cold_compression": true
    },
    "embedding": {
      "model": "all-MiniLM-L6-v2",
      "cache_size": 2000
    },
    "backup": {
      "enabled": true,
      "frequency_hours": 1
    }
  },

  "logging": {
    "level": "debug",
    "file": "~/.brainwires/logs/cli.log",
    "rotation": {
      "max_size_mb": 50,
      "max_files": 10
    },
    "structured": true
  },

  "ui": {
    "theme": "default",
    "show_token_count": true,
    "show_cost_estimate": true,
    "markdown_rendering": true,
    "show_validation_details": true
  },

  "notes": [
    "This configuration prioritizes correctness over speed and cost.",
    "MDAP is enabled with k=5 agents for maximum reliability.",
    "All write operations require explicit approval.",
    "File backups are created before modifications.",
    "Extended logging for debugging and audit trails."
  ]
}
