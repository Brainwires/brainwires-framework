# brainwires-chat-pwa — local environment overrides.
#
# Copy to .env (which is git-ignored) and edit to taste. Docker Compose
# auto-loads .env from this directory; values here override the defaults
# baked into docker-compose.yml.
#
#   cp .env.example .env

# ── Host port ──────────────────────────────────────────────────────────
# The container always listens on 80 internally. HOST_PORT is just the
# host-side mapping. Default 8888 to avoid collisions with the more
# common dev ports (3000, 5173, 8080, 8000).
HOST_PORT=8888

# ── Build metadata ─────────────────────────────────────────────────────
# Stamped into build-info.js at container start; surfaced in the
# Settings panel of the PWA. Leaving blank uses the values esbuild wrote
# during the image build (the git short SHA and the build timestamp).
#BUILD_VERSION=0.1.0
#BUILD_COMMIT=
#BUILD_DATE=

# ── Dev mode ───────────────────────────────────────────────────────────
# When true, the PWA exposes additional debug surfaces (verbose logs,
# experimental settings) AND boot.js skips service-worker registration so
# edits to the static bundle land in the browser without SW cache hits.
#
# Set this true in `.env` (or export DEV_MODE=true) when running
# `docker compose watch` to disable the service worker. `./web/dev.sh`
# already exports it for you. Leave it `false` for plain
# `docker compose up`.
DEV_MODE=false
